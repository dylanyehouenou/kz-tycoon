# ==========================================================
#  KZ TYCOON — Exemple de configuration d'environnement
# ==========================================================
#  COMMENT L'UTILISER :
#    1) Copie ce fichier en ".env" (qui, lui, n'est JAMAIS versionné) :
#         cp .env.example .env
#    2) Génère une vraie clé secrète aléatoire :
#         python -c "import secrets; print(secrets.token_hex(32))"
#    3) Colle la clé obtenue dans SECRET_KEY ci-dessous (dans ton .env).
# ----------------------------------------------------------

# Clé secrète Flask (protège les sessions/cookies). OBLIGATOIRE et ALÉATOIRE.
SECRET_KEY=colle-ici-une-cle-aleatoire-generee

# Mode debug : 1 = développement local, 0 = production (serveur Debian).
FLASK_DEBUG=1

# Adresse d'écoute : 0.0.0.0 pour être accessible depuis le réseau / le serveur.
HOST=0.0.0.0

# Port du serveur web (modifiable selon le déploiement).
PORT=5000

# Chemin du fichier base de données SQLite.
DATABASE=database/kz_tycoon.db
